# ========================================================
#  YORU notification-service - configuracion
# ========================================================
#
# Copia este archivo a .env y rellena los valores. Sin .env el servicio
# corre en modo jsonTransport (solo loguea, no envia correos).
#
# Cuando este .env existe, dotenv lo carga automaticamente al arrancar
# el servicio (npm run dev / iniciar.py).
#
# Reinicia la ventana del notification-service tras tocar este archivo.

RABBITMQ_URL="amqp://yoru:yoru_dev@localhost:5672"
PORT=3005
HOST=0.0.0.0

# --------------------------------------------------------
# Modo del transporte: "json" (default, solo loguea) o "smtp"
# --------------------------------------------------------
# MAIL_TRANSPORT=smtp


# ========================================================
#  SMS - codigo de verificacion al vincular linea
# ========================================================
#
# Elige UN proveedor con SMS_TRANSPORT. Sin definirlo, los codigos SMS solo
# se imprimen en la consola (modo demo).
#
# --------------------------------------------------------
#  OPCION A: TU PROPIO ANDROID con "Traccar SMS Gateway"  (GRATIS, recomendada)
# --------------------------------------------------------
# App "Traccar SMS Gateway" (Anton Tananaev) - facil de hallar en Play Store:
#
#  1. Instala "Traccar SMS Gateway" desde Play Store.
#  2. Abrela y concede el permiso de Enviar SMS.
#  3. La app muestra/define una API KEY y queda escuchando en el puerto 8082.
#     Anota la IP del telefono (Ajustes WiFi) y la key.
#  4. El telefono y la PC del backend deben estar en la MISMA red WiFi.
#  5. Pega los datos abajo (la URL es http://<ip>:8082/ con la barra final).
#  6. Reinicia la ventana del notification-service.
#
# SMS_TRANSPORT=traccar
# TRACCAR_SMS_URL=http://192.168.1.50:8082/
# TRACCAR_SMS_KEY=la_api_key_de_la_app
# SMS_COUNTRY_CODE=+52
#
#  Formato del numero al usar la SIM local. Por defecto "national" (10 digitos),
#  porque muchos operadores (ej. Telcel/MX) NO entregan SMS locales en formato
#  internacional "+52...". Cambia a "e164" solo si tu operador lo requiere.
# SMS_NUMBER_FORMAT=national
#
# --------------------------------------------------------
#  OPCION B: TU PROPIO ANDROID con "SMS Gateway for Android" (sms-gate.app)
# --------------------------------------------------------
# Usa la app gratuita y open-source "SMS Gateway for Android" (sms-gate.app):
#
#  1. Instala la app en tu telefono Android:
#       https://sms-gate.app  /  Play Store / APK de GitHub (capcom6/android-sms-gateway)
#  2. Abre la app y ACTIVA el modo "Local Server" (servidor local).
#     La app te mostrara:
#        - una direccion tipo  http://192.168.1.50:8080
#        - un usuario y un password (generados por la app)
#  3. El telefono y la PC que corre el backend deben estar en la MISMA red WiFi.
#  4. Concede a la app el permiso de "Enviar SMS".
#  5. Pega los datos abajo. La URL termina en  /message
#  6. Reinicia la ventana del notification-service.
#
#  Nota: con SIM normal, tu operador puede limitar cuantos SMS envias por minuto.
#
# SMS_TRANSPORT=android
# ANDROID_SMS_URL=http://192.168.1.50:8080/message
# ANDROID_SMS_USER=sms
# ANDROID_SMS_PASSWORD=el_password_que_muestra_la_app
# SMS_COUNTRY_CODE=+52
#
# --------------------------------------------------------
#  OPCION C: TWILIO  (nube, trial/pago)
# --------------------------------------------------------
# Para enviar SMS REALES con Twilio:
#
#  1. Crea una cuenta en https://www.twilio.com/try-twilio (trial gratis).
#  2. En la consola de Twilio copia tu Account SID y Auth Token.
#  3. Consigue un numero emisor:
#       - Trial: usa el numero que Twilio te asigna gratis (TWILIO_FROM), o
#       - un Messaging Service (TWILIO_MESSAGING_SERVICE_SID).
#  4. IMPORTANTE (cuenta trial): solo puedes enviar a numeros que hayas
#     VERIFICADO en Twilio (Verified Caller IDs) y el SMS llega con el
#     prefijo "Sent from your Twilio trial account".
#  5. Tras instalar la dependencia (npm install twilio) y poner estas
#     variables, reinicia la ventana del notification-service.
#
#  Los telefonos de 10 digitos se convierten a E.164 con SMS_COUNTRY_CODE
#  (Mexico = +52). Si capturas el numero con +, se respeta tal cual.
#
# SMS_TRANSPORT=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+15555555555
# # Alternativa a TWILIO_FROM:
# # TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMS_COUNTRY_CODE=+52


# ========================================================
#  RECETARIO DE PROVEEDORES SMTP
# ========================================================
#
# --------------------------------------------------------
#  GMAIL  (la opcion mas facil para demo)
# --------------------------------------------------------
# Requisitos:
#  1. Activa la verificacion en 2 pasos en tu cuenta Google.
#  2. Genera una "Contrasena de aplicacion":
#       https://myaccount.google.com/apppasswords
#     Selecciona "Otra" -> "Yoru" -> Generar.
#  3. Copia la contrasena de 16 caracteres SIN espacios en SMTP_PASS.
#  4. SMTP_USER y MAIL_FROM deben ser el MISMO correo (Gmail rechaza
#     enviar como otra direccion).
#
# MAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu.correo@gmail.com
# SMTP_PASS=tuapppassword16chars
# MAIL_FROM=Yoru <tu.correo@gmail.com>
#
# --------------------------------------------------------
#  OUTLOOK / HOTMAIL
# --------------------------------------------------------
# MAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=tu.correo@outlook.com
# SMTP_PASS=tu_password
# MAIL_FROM=Yoru <tu.correo@outlook.com>
#
# --------------------------------------------------------
#  RESEND  (free tier; envio real requiere dominio verificado)
# --------------------------------------------------------
# MAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxx
# MAIL_FROM=Yoru <onboarding@resend.dev>
#
# --------------------------------------------------------
#  ETHEREAL  (cuenta gratuita de prueba: webmail propio)
# --------------------------------------------------------
# Crea cuenta en https://ethereal.email/create y pega los datos.
# Los "correos" se ven en su webmail (no llegan a Gmail real).
# MAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.ethereal.email
# SMTP_PORT=587
# SMTP_USER=xxx@ethereal.email
# SMTP_PASS=xxxxxxxxxxxxxxxx
# MAIL_FROM=Yoru <xxx@ethereal.email>
