generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(uuid())
  curp          String      @unique
  telefono      String      @unique
  email         String?     @unique
  passwordHash  String?     @map("password_hash")
  passwordSalt  String?     @map("password_salt")
  nombre        String?
  estado        EstadoUser  @default(pendiente)

  // Solo cuando committed=true se considera el alta "real".
  committed     Boolean     @default(false)
  emailVerified Boolean     @default(false) @map("email_verified")

  // Codigo de verificacion de email (5 digitos) durante el registro.
  emailVerificationCode      String?   @map("email_verification_code")
  emailVerificationExpira    DateTime? @map("email_verification_expira")
  emailVerificationLastSent  DateTime? @map("email_verification_last_sent")

  // Datos pendientes del registro (se mueven a kyc/pki/telecom al verificar email)
  pendingIneS3        String?  @map("pending_ine_s3")
  pendingSelfieS3     String?  @map("pending_selfie_s3")
  pendingPublicKeyPem String?  @map("pending_public_key_pem") @db.Text

  // Codigo para revocar llave (5 digitos)
  codigoRevocacion        String?   @map("codigo_revocacion")
  codigoRevocacionExpira  DateTime? @map("codigo_revocacion_expira")

  // Token corto para flujo de recuperacion (validado por firma .pem)
  recoveryToken        String?   @map("recovery_token")
  recoveryTokenExpira  DateTime? @map("recovery_token_expira")

  // Codigo de reseteo de contrasena enviado por correo (olvido de contrasena, sin .pem)
  passwordResetCodigo  String?   @map("password_reset_codigo")
  passwordResetExpira  DateTime? @map("password_reset_expira")

  // Verificacion por SMS al vincular una nueva linea (filtro de seguridad extra).
  // Guarda el telefono en proceso, el codigo enviado, su expiracion y si ya
  // fue confirmado por el usuario. Se limpia al concretar la vinculacion.
  lineaVerifTelefono   String?   @map("linea_verif_telefono")
  lineaVerifCodigo     String?   @map("linea_verif_codigo")
  lineaVerifExpira     DateTime? @map("linea_verif_expira")
  lineaVerifConfirmada Boolean   @default(false) @map("linea_verif_confirmada")

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  sessions   Session[]
  challenges Challenge[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Challenge {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  nonce     String
  proposito String   @default("login")          // login | recovery
  usado     Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("challenges")
}

enum EstadoUser {
  pendiente
  activo
  bloqueado
}
